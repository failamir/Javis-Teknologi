# Database Connection String
# Example for Vercel Postgres: postgresql://username:password@hostname:port/database?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/javis_db?schema=public"

# Secret key for JWT encryption (generate a strong random string)
JWT_SECRET="your_super_secret_random_string_here"

# Next.js Environment
NODE_ENV="development"
